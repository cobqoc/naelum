# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 카카오 공유 SDK (선택 - https://developers.kakao.com 앱 생성 후 JavaScript 키 입력)
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=

# Sentry (선택 - 에러 모니터링, 없으면 비활성화)
# https://sentry.io 에서 프로젝트 생성 후 DSN 입력
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# 2FA TOTP 암호화 키 (선택 - 2단계 인증 사용 시 필수)
# openssl rand -hex 32 로 생성
TOTP_ENCRYPTION_KEY=

# Push Notification VAPID Keys (선택 - 푸시 알림 사용 시 필수)
# npx web-push generate-vapid-keys 로 생성
VAPID_EMAIL=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Rate Limiting (프로덕션에서 활성화 권장)
ENABLE_RATE_LIMITING=

# Resend (선택 - 문의 접수 시 개발자 이메일 알림)
# https://resend.com 에서 API 키 발급
RESEND_API_KEY=
DEVELOPER_NOTIFY_EMAIL=