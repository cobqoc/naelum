# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!env.example

# 이 프로젝트는 npm을 사용. 다른 패키지 매니저 lock 파일 추적 차단
pnpm-lock.yaml
yarn.lock

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local tool configs (should not be committed)
.claude/
.mcp.json
*.code-workspace

# test output
test-results/
playwright-report/

# windows artifacts
nul

.vercel

# Supabase CLI temp files
supabase/.temp/
